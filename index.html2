<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#FF4B2B">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <title>Sahil Yousafzai - Food Delivery</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: #0a0a0a;
            min-height: 100vh;
            overflow-x: hidden;
            color: white;
        }

        .app-container {
            max-width: 480px;
            margin: 0 auto;
            min-height: 100vh;
            position: relative;
            background: #0a0a0a;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
        }

        .header {
            background: linear-gradient(135deg, #FF4B2B 0%, #FF416C 100%);
            padding: 20px;
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom-left-radius: 30px;
            border-bottom-right-radius: 30px;
            box-shadow: 0 10px 30px rgba(255, 75, 43, 0.3);
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 24px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .logo span {
            color: #FFD700;
        }

        .delivery-badge {
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 5px;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .hero {
            padding: 30px 20px;
            text-align: center;
            background: linear-gradient(180deg, #FF4B2B 0%, #FF416C 50%, #0a0a0a 100%);
        }

        .hero h1 {
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 10px;
            line-height: 1.2;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .hero p {
            font-size: 16px;
            opacity: 0.9;
            margin-bottom: 20px;
        }

        .food-showcase {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin: 30px 0;
            flex-wrap: wrap;
        }

        .food-item {
            width: 100px;
            height: 100px;
            border-radius: 20px;
            object-fit: cover;
            border: 3px solid rgba(255,255,255,0.3);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            animation: float 3s ease-in-out infinite;
        }

        .food-item:nth-child(2) { animation-delay: 0.5s; }
        .food-item:nth-child(3) { animation-delay: 1s; }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }

        .menu-section {
            background: #1a1a1a;
            border-radius: 40px 40px 0 0;
            padding: 30px 20px;
            margin-top: -20px;
            min-height: 600px;
        }

        .section-title {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 2px;
            background: linear-gradient(90deg, #FF4B2B, transparent);
        }

        .menu-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 30px;
        }

        .menu-card {
            background: linear-gradient(145deg, #2a2a2a, #1f1f1f);
            border-radius: 20px;
            padding: 20px;
            text-align: center;
            border: 2px solid transparent;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .menu-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #FF4B2B, #FF6B35);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .menu-card:hover::before,
        .menu-card.active::before {
            transform: scaleX(1);
        }

        .menu-card:hover,
        .menu-card.active {
            border-color: #FF4B2B;
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(255, 75, 43, 0.2);
        }

        .menu-icon {
            font-size: 40px;
            margin-bottom: 10px;
            display: block;
        }

        .menu-name {
            font-size: 16px;
            font-weight: 600;
            color: white;
        }

        .menu-price {
            font-size: 14px;
            color: #FF6B35;
            font-weight: 700;
            margin-top: 5px;
        }

        .action-buttons {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-top: 30px;
        }

        .btn {
            padding: 18px 30px;
            border-radius: 15px;
            border: none;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255,255,255,0.3);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn:active::before {
            width: 300px;
            height: 300px;
        }

        .btn-order {
            background: linear-gradient(135deg, #FF4B2B 0%, #FF416C 100%);
            box-shadow: 0 10px 30px rgba(255, 75, 43, 0.4);
            animation: glow 2s infinite;
        }

        @keyframes glow {
            0%, 100% { box-shadow: 0 10px 30px rgba(255, 75, 43, 0.4); }
            50% { box-shadow: 0 10px 40px rgba(255, 75, 43, 0.6); }
        }

        .btn-call {
            background: linear-gradient(135deg, #00C853 0%, #00E676 100%);
            box-shadow: 0 10px 30px rgba(0, 200, 83, 0.3);
        }

        .btn:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
        }

        .btn:active {
            transform: translateY(0);
        }

        .delivery-banner {
            background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
            color: #000;
            padding: 15px;
            border-radius: 15px;
            text-align: center;
            font-weight: 700;
            margin: 20px 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            animation: slideIn 0.5s ease;
            box-shadow: 0 5px 20px rgba(255, 215, 0, 0.3);
        }

        @keyframes slideIn {
            from { transform: translateX(-100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        .footer {
            text-align: center;
            padding: 30px 20px;
            color: #666;
            font-size: 14px;
            background: #1a1a1a;
        }

        .social-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 15px;
        }

        .social-icon {
            width: 40px;
            height: 40px;
            background: #2a2a2a;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            transition: all 0.3s ease;
        }

        .social-icon:hover {
            background: #FF4B2B;
            transform: translateY(-3px);
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.9);
            z-index: 1000;
            justify-content: center;
            align-items: flex-end;
            padding: 0;
        }

        .modal-content {
            background: #1a1a1a;
            border-radius: 30px 30px 0 0;
            padding: 30px 20px;
            width: 100%;
            max-width: 480px;
            max-height: 80vh;
            overflow-y: auto;
            border-top: 3px solid #FF4B2B;
            animation: slideUp 0.3s ease;
        }

        @keyframes slideUp {
            from { transform: translateY(100%); }
            to { transform: translateY(0); }
        }

        .modal h2 {
            color: #FF4B2B;
            margin-bottom: 20px;
            font-size: 24px;
            text-align: center;
        }

        .modal-item {
            background: #2a2a2a;
            padding: 15px;
            border-radius: 15px;
            margin: 10px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .quantity-control {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .qty-btn {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            border: none;
            background: #FF4B2B;
            color: white;
            font-weight: bold;
            cursor: pointer;
            font-size: 18px;
            transition: transform 0.2s;
        }

        .qty-btn:active {
            transform: scale(0.9);
        }

        .close-modal {
            margin-top: 20px;
            background: #333;
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 25px;
            cursor: pointer;
            font-weight: 600;
            width: 100%;
            font-size: 16px;
        }

        .loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #0a0a0a;
            z-index: 9999;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: opacity 0.5s;
        }

        .loader-content {
            text-align: center;
        }

        .loader-logo {
            font-size: 36px;
            font-weight: 800;
            color: #FF4B2B;
            animation: pulse 1.5s infinite;
            line-height: 1.2;
        }

        .loader.hidden {
            opacity: 0;
            pointer-events: none;
        }

        .info-card {
            margin-top: 30px;
            text-align: center;
            padding: 20px;
            background: linear-gradient(135deg, rgba(255,75,43,0.1), rgba(255,107,53,0.1));
            border-radius: 20px;
            border: 1px solid rgba(255,75,43,0.3);
        }

        .info-card h3 {
            color: #FF6B35;
            margin-bottom: 10px;
            font-size: 18px;
        }

        .info-card p {
            color: #aaa;
            font-size: 14px;
            line-height: 1.6;
        }

        @media (max-width: 480px) {
            .app-container {
                max-width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="loader" id="loader">
        <div class="loader-content">
            <div class="loader-logo">SAHIL<br>YOUSAFZAI</div>
            <p style="margin-top: 20px; color: #666; font-size: 14px;">Loading...</p>
        </div>
    </div>

    <div class="app-container">
        <header class="header">
            <div class="header-content">
                <div class="logo">Sahil <span>Yousafzai</span></div>
                <div class="delivery-badge">
                    <span>🚀</span>
                    <span>Fast</span>
                </div>
            </div>
        </header>

        <section class="hero">
            <h1>Hungry?<br>We Got You!</h1>
            <p>Best burgers & fast food in town</p>
            
            <div class="food-showcase">
                <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=400&h=400&fit=crop" alt="Burger" class="food-item">
                <img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=400&h=400&fit=crop" alt="Pizza" class="food-item">
                <img src="https://images.unsplash.com/photo-1529006557810-274b9b2fc783?w=400&h=400&fit=crop" alt="Shawarma" class="food-item">
            </div>

            <div class="delivery-banner">
                <span>🛵</span>
                <span>FREE HOME DELIVERY!</span>
            </div>
        </section>

        <section class="menu-section">
            <h2 class="section-title">Our Menu</h2>
            
            <div class="menu-grid">
                <div class="menu-card" onclick="selectItem(this, 'Burger')">
                    <span class="menu-icon">🍔</span>
                    <div class="menu-name">Burger</div>
                    <div class="menu-price">From Rs. 350</div>
                </div>
                
                <div class="menu-card" onclick="selectItem(this, 'Pizza')">
                    <span class="menu-icon">🍕</span>
                    <div class="menu-name">Pizza</div>
                    <div class="menu-price">From Rs. 599</div>
                </div>
                
                <div class="menu-card" onclick="selectItem(this, 'Shawarma')">
                    <span class="menu-icon">🌯</span>
                    <div class="menu-name">Shawarma</div>
                    <div class="menu-price">From Rs. 250</div>
                </div>
                
                <div class="menu-card" onclick="selectItem(this, 'Hotdog')">
                    <span class="menu-icon">🌭</span>
                    <div class="menu-name">Hotdog</div>
                    <div class="menu-price">From Rs. 200</div>
                </div>
                
                <div class="menu-card" onclick="selectItem(this, 'Noodles')" style="grid-column: 1 / -1;">
                    <span class="menu-icon">🍜</span>
                    <div class="menu-name">Noodles</div>
                    <div class="menu-price">From Rs. 300</div>
                </div>
            </div>

            <div class="action-buttons">
                <button class="btn btn-order" onclick="openOrderModal()">
                    <span>🛒</span>
                    <span>Order Now</span>
                </button>
                
                <a href="tel:03195355671" class="btn btn-call">
                    <span>📞</span>
                    <span>Call: 0319-5355671</span>
                </a>
            </div>

            <div class="info-card">
                <h3>📍 Visit Us</h3>
                <p>Open Daily: 11:00 AM - 11:00 PM<br>Fresh Food, Fast Service!</p>
            </div>
        </section>

        <footer class="footer">
            <div class="social-links">
                <div class="social-icon">📘</div>
                <div class="social-icon">📸</div>
                <div class="social-icon">🐦</div>
            </div>
            <p>&copy; 2024 Sahil Yousafzai Restaurant<br>All Rights Reserved</p>
        </footer>
    </div>

    <div class="modal" id="orderModal" onclick="closeModalOutside(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <h2>Your Order</h2>
            <div id="orderItems">
                <p style="color: #666; padding: 20px; text-align: center;">Select items from the menu</p>
            </div>
            <div style="margin-top: 20px; padding-top: 20px; border-top: 2px solid #333; text-align: center;">
                <h3 style="color: #FF4B2B; font-size: 20px;">Total: <span id="totalPrice">Rs. 0</span></h3>
            </div>
            <button class="btn btn-order" style="margin-top: 20px; width: 100%;" onclick="placeOrder()">
                Confirm Order
            </button>
            <button class="close-modal" onclick="closeModal()">Close</button>
        </div>
    </div>

    <script>
        window.addEventListener('load', () => {
            setTimeout(() => {
                document.getElementById('loader').classList.add('hidden');
            }, 1500);
        });

        let selectedItems = {};
        const prices = {
            'Burger': 350,
            'Pizza': 599,
            'Shawarma': 250,
            'Hotdog': 200,
            'Noodles': 300
        };

        function selectItem(element, itemName) {
            element.classList.toggle('active');
            
            if (element.classList.contains('active')) {
                if (!selectedItems[itemName]) {
                    selectedItems[itemName] = 1;
                }
            } else {
                delete selectedItems[itemName];
            }
            
            element.style.transform = 'scale(0.95)';
            setTimeout(() => {
                element.style.transform = '';
            }, 200);
        }

        function openOrderModal() {
            const modal = document.getElementById('orderModal');
            const orderItems = document.getElementById('orderItems');
            
            if (Object.keys(selectedItems).length === 0) {
                alert('Please select at least one item from the menu!');
                return;
            }
            
            let html = '';
            let total = 0;
            
            for (let [item, qty] of Object.entries(selectedItems)) {
                const price = prices[item];
                total += price * qty;
                html += `
                    <div class="modal-item">
                        <span style="font-weight: 600;">${item}</span>
                        <div class="quantity-control">
                            <button class="qty-btn" onclick="updateQty('${item}', -1)">−</button>
                            <span style="font-weight: 700; min-width: 20px;">${qty}</span>
                            <button class="qty-btn" onclick="updateQty('${item}', 1)">+</button>
                        </div>
                    </div>
                `;
            }
            
            orderItems.innerHTML = html;
            document.getElementById('totalPrice').textContent = `Rs. ${total}`;
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function updateQty(item, change) {
            selectedItems[item] += change;
            if (selectedItems[item] <= 0) {
                delete selectedItems[item];
                document.querySelectorAll('.menu-card').forEach(card => {
                    if (card.textContent.includes(item)) {
   
